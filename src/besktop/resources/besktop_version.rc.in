#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404B0"
        BEGIN
            VALUE "CompanyName", "BensonLaur\0"
            VALUE "FileDescription", "@BESKTOP_PRODUCT_NAME@\0"
            VALUE "FileVersion", "@BESKTOP_VERSION_FILE@\0"
            VALUE "InternalName", "Besktop\0"
            VALUE "LegalCopyright", "Copyright (C) BensonLaur\0"
            VALUE "OriginalFilename", "Besktop.exe\0"
            VALUE "ProductName", "@BESKTOP_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@PROJECT_VERSION@\0"
            VALUE "Comments", "Safe Windows desktop entertainment tool\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200
    END
END
